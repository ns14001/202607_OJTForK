<Window x:Class="EquipmentManager.Views.TopView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="社内備品管理システム"
        Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Background="#F0F4F8">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="社内備品管理システム"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>

            <TextBlock Text="社内の備品を一元管理するシステムです。"
                       FontSize="14"
                       Foreground="#7F8C8D"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,48"/>

            <Button x:Name="StartButton"
                    Content="開  始"
                    Width="200"
                    Height="48"
                    FontSize="16"
                    Background="#3498DB"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="StartButton_Click"/>

        </StackPanel>
    </Grid>
</Window>
