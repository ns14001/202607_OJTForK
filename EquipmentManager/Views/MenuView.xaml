<Window x:Class="EquipmentManager.Views.MenuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="社内備品管理システム - メニュー"
        Height="520" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- メニューボタンの共通スタイル -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="240"/>
            <Setter Property="Height"          Value="44"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="Margin"          Value="0,8"/>
            <Setter Property="Background"      Value="#3498DB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>

        <!-- 未実装ボタンは少し色を変えてわかりやすくする -->
        <Style x:Key="MenuButtonNotImplementedStyle" TargetType="Button"
               BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#95A5A6"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F4F8">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="メニュー"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32"/>

            <!-- 実装済み -->
            <Button Content="備品一覧"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="EquipmentListButton_Click"/>

            <!-- 以下は未実装（課題として実装してください） -->
            <Button Content="社員一覧"
                    Style="{StaticResource MenuButtonNotImplementedStyle}"
                    Click="NotImplementedButton_Click"/>

            <Button Content="貸出中一覧"
                    Style="{StaticResource MenuButtonNotImplementedStyle}"
                    Click="NotImplementedButton_Click"/>

            <Button Content="貸出履歴"
                    Style="{StaticResource MenuButtonNotImplementedStyle}"
                    Click="NotImplementedButton_Click"/>

            <Button Content="CSV 出力"
                    Style="{StaticResource MenuButtonNotImplementedStyle}"
                    Click="NotImplementedButton_Click"/>

        </StackPanel>
    </Grid>
</Window>
