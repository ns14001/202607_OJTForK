<UserControl x:Class="EquipmentManager.Views.EquipmentListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F7FA">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- タイトル -->
            <RowDefinition Height="Auto"/>
            <!-- 一覧エリア（実装してください） -->
            <RowDefinition Height="*"/>
            <!-- ボタンエリア（実装してください） -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0"
                   Text="備品一覧"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,16"/>

        <!--
            TODO: ここに DataGrid を配置して備品一覧を表示してください。

            実装のヒント:
              1. DataGrid を配置し、AutoGenerateColumns="False" に設定する
              2. 表示する列: 備品コード / 備品名 / カテゴリ / 状態 / 登録日 / 備考
              3. コードビハインド（EquipmentListView.xaml.cs）で EquipmentService.GetAll() を呼び出し、
                 DataGrid.ItemsSource にセットするとデータが表示される

            参考: EquipmentService.cs に GetAll() メソッドが実装されています。
        -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#DDE3EE"
                BorderThickness="1">
            <TextBlock Text="ここに DataGrid を実装してください"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Foreground="#B0BED4"/>
        </Border>

        <!--
            TODO: ここにボタンを配置してください。

            配置するボタン: 新規登録 / 編集 / 削除 / 貸出 / 返却 / 履歴表示

            実装のヒント:
              ・選択中の行がない場合はボタンを無効化する（Button.IsEnabled）
              ・備品の状態によって有効/無効を切り替える（「利用可能」→貸出可 など）
        -->

    </Grid>
</UserControl>
