<Window x:Class="EquipmentManager.Views.EquipmentListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="社内備品管理システム - 備品一覧"
        Height="600" Width="920"
        WindowStartupLocation="CenterOwnerScreen">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="76"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Margin"          Value="0,0,6,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Background"      Value="#3498DB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- タイトル行 -->
            <RowDefinition Height="Auto"/>
            <!-- 一覧 -->
            <RowDefinition Height="*"/>
            <!-- ボタン行 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトル -->
        <TextBlock Grid.Row="0"
                   Text="備品一覧"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   Margin="0,0,0,12"/>

        <!-- 備品一覧テーブル -->
        <DataGrid Grid.Row="1"
                  x:Name="EquipmentDataGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  AlternatingRowBackground="#F9F9F9"
                  RowBackground="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="備品コード" Binding="{Binding EquipmentCode}" Width="100"/>
                <DataGridTextColumn Header="備品名"     Binding="{Binding Name}"          Width="200"/>
                <DataGridTextColumn Header="カテゴリ"   Binding="{Binding Category}"       Width="130"/>
                <DataGridTextColumn Header="状態"       Binding="{Binding Status}"         Width="90"/>
                <DataGridTextColumn Header="登録日"     Binding="{Binding RegisteredDate}" Width="100"/>
                <DataGridTextColumn Header="備考"       Binding="{Binding Note}"           Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- ボタンエリア -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <!-- 課題：以下のボタンを実装してください -->
                <Button Content="新規登録" Style="{StaticResource ActionButtonStyle}" Click="NotImplementedButton_Click"/>
                <Button Content="編集"     Style="{StaticResource ActionButtonStyle}" Click="NotImplementedButton_Click"/>
                <Button Content="削除"     Style="{StaticResource ActionButtonStyle}" Click="NotImplementedButton_Click"/>
                <Button Content="貸出"     Style="{StaticResource ActionButtonStyle}" Click="NotImplementedButton_Click"/>
                <Button Content="返却"     Style="{StaticResource ActionButtonStyle}" Click="NotImplementedButton_Click"/>
                <Button Content="履歴表示" Style="{StaticResource ActionButtonStyle}" Click="NotImplementedButton_Click"/>
            </StackPanel>

            <Button Content="戻る"
                    HorizontalAlignment="Right"
                    Width="76"
                    Height="32"
                    FontSize="13"
                    Background="#95A5A6"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="BackButton_Click"/>
        </Grid>
    </Grid>
</Window>
