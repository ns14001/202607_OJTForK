<Window x:Class="EquipmentManager.Views.ShellView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="社内備品管理システム"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        MinHeight="520" MinWidth="800">

    <Window.Resources>

        <!-- ─────────────────────────────────────────
             ナビゲーションボタン（通常状態）
             ─────────────────────────────────────────
             WPF のデフォルトボタンは立体的なテンプレートなので、
             ControlTemplate を定義してサイドバー向けのフラットなデザインに変更している。
        -->
        <ControlTemplate x:Key="NavButtonTemplate" TargetType="Button">
            <Border x:Name="Root" Background="{TemplateBinding Background}">
                <!-- 左端のアクセントバー（選択中は青く表示） -->
                <Grid>
                    <Border x:Name="AccentBar"
                            Width="3"
                            Background="#3498DB"
                            HorizontalAlignment="Left"
                            Visibility="Collapsed"/>
                    <ContentPresenter Margin="24,0,16,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Root" Property="Background" Value="#283045"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ナビゲーションボタン（選択中状態）: アクセントバーを表示する -->
        <ControlTemplate x:Key="NavButtonActiveTemplate" TargetType="Button">
            <Border x:Name="Root" Background="#283045">
                <Grid>
                    <Border Width="3"
                            Background="#3498DB"
                            HorizontalAlignment="Left"/>
                    <ContentPresenter Margin="24,0,16,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"/>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Root" Property="Background" Value="#2E3B52"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- 通常のナビゲーションボタンスタイル -->
        <Style x:Key="NavItemStyle" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="Foreground"              Value="#8090A8"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize"                Value="14"/>
            <Setter Property="Height"                  Value="42"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="Template"                Value="{StaticResource NavButtonTemplate}"/>
        </Style>

        <!-- 選択中のナビゲーションボタンスタイル -->
        <Style x:Key="NavItemActiveStyle" TargetType="Button" BasedOn="{StaticResource NavItemStyle}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template"   Value="{StaticResource NavButtonActiveTemplate}"/>
        </Style>

        <!-- ナビゲーショングループのラベル（小見出し） -->
        <Style x:Key="NavGroupLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Foreground" Value="#4A5B72"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin"     Value="16,20,0,4"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- サイドバー（固定幅） -->
            <ColumnDefinition Width="220"/>
            <!-- メインコンテンツエリア（残り全部） -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════
             左カラム：サイドバー
        ══════════════════════════════════ -->
        <Grid Grid.Column="0" Background="#1E2535">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- アプリ名ヘッダー -->
            <Border Grid.Row="0" Background="#171D2B" Padding="20,18">
                <TextBlock Text="社内備品管理"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#E8EEF8"/>
            </Border>

            <!-- ナビゲーションメニュー -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- 備品管理 グループ -->
                    <TextBlock Text="備品管理" Style="{StaticResource NavGroupLabelStyle}"/>
                    <Button x:Name="BtnEquipmentList"
                            Content="備品一覧"
                            Style="{StaticResource NavItemActiveStyle}"
                            Click="BtnEquipmentList_Click"/>

                    <!-- 社員管理 グループ -->
                    <TextBlock Text="社員管理" Style="{StaticResource NavGroupLabelStyle}"/>
                    <Button x:Name="BtnEmployeeList"
                            Content="社員一覧"
                            Style="{StaticResource NavItemStyle}"
                            Click="NotImplementedButton_Click"/>

                    <!-- 貸出管理 グループ -->
                    <TextBlock Text="貸出管理" Style="{StaticResource NavGroupLabelStyle}"/>
                    <Button x:Name="BtnRentingList"
                            Content="貸出中一覧"
                            Style="{StaticResource NavItemStyle}"
                            Click="NotImplementedButton_Click"/>
                    <Button x:Name="BtnRentalHistory"
                            Content="貸出履歴"
                            Style="{StaticResource NavItemStyle}"
                            Click="NotImplementedButton_Click"/>

                    <!-- 出力 グループ -->
                    <TextBlock Text="出力" Style="{StaticResource NavGroupLabelStyle}"/>
                    <Button x:Name="BtnCsvExport"
                            Content="CSV 出力"
                            Style="{StaticResource NavItemStyle}"
                            Click="NotImplementedButton_Click"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════════════════
             右カラム：メインコンテンツエリア
             ContentControl に UserControl をセットすることで画面を切り替える
        ══════════════════════════════════ -->
        <ContentControl Grid.Column="1"
                        x:Name="MainContent"
                        Background="#F5F7FA"/>

    </Grid>
</Window>
